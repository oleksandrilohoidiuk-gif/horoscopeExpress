<style>
:root {
    background: #856e47;  
    color: #ffffff;           
    color-scheme: dark;  
}

html, body {
    height: 100% !important;
    margin: 0;
    }

body {
    background-color: #856e47;  
    margin-top: 0px;
    min-height: 100vh;
    background-color: `#ff003737;
    color: white;
    font-family:'Calibri', sans-serif;
}
.filter-container {
    width: 965px;
    margin: 90px auto 20px auto; 
    background: #0a0a1a;
    backdrop-filter: blur(10px);
    border-radius: 15px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    padding: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
}

.filter-select {
    background: #0b0b1d;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 10px 15px;
    border-radius: 8px;
    font-size: 18px;
    outline: none;
    cursor: pointer;
    font-family: 'Calibri', sans-serif;
}

.filter-select option {
    background: #0a0a1a;
}

.filter-btn {
    background: transparent;
    color: #white;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 10px 25px;
    font-size: 18px;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    transition: 0.3s;
 }

.filter-btn:hover {
   background: rgba(255, 255, 255, 0.1);
}

.filter-btn-reset {
    background: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 10px 25px;
    font-size: 18px;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.3s;
}

.filter-btn-reset:hover {
    background: rgba(255, 255, 255, 0.1);
}

table {
    width: 1000px;
    margin: 50px auto;
    border-collapse: collapse;
    background: #0a0a1a;
    backdrop-filter: blur(10px);         
    border-radius: 15px;
    overflow: hidden;
    border: 1px solid rgb(255, 255, 255);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
}

table th {
    background: #090916;
    color: #ffffff;
    padding: 14px;
    text-transform: uppercase;
    font-size: 20px;
    text-align: center;
    letter-spacing: 1px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

table td {
    background: #0b0b1d;
    padding: 12px 15px;
    color: rgba(255, 255, 255, 0.9);
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    font-size: 20px;
}

table tr:hover {
    background: rgba(255, 255, 255, 0.1);
    transition: 0.3s;
}

.btn-list {
    margin-left: 850px;
    margin-top: 200px;
    color:rgb(255, 255, 255);
}
.reaction-cell {
    text-align: center;
    vertical-align: middle;
}

.reaction-group {
    display: inline-flex;
    gap: 8px;
}

.reaction-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}

.btn-reaction {
    border: none;
    background: none;
    font-size: 24px;
    cursor: pointer;
    padding: 4px;
    transition: transform 0.1s, filter 0.1s;
}

.btn-reaction.active {
  transform: scale(1.5);
  filter: brightness(1.2) drop-shadow(0 0 6px rgba(255, 255, 255, 0.041));
}


.reaction-count {
    font-size: 15px;
    min-width: 12px;
}

.btn-back {
    position: absolute;
    top: 20px;
    left: 40px;
    text-decoration: none;
    font-size: 50px;
    color: #c9a96e;
}
</style>
            </button>
            <div><a href="/" class="btn-back">🏠︎</a></div>
            <form action="/db" method="GET" class="filter-container">
        
        <select name="sign" class="filter-select">
            <option value="">Всі знаки</option>
            <option value="Козоріг" {{#if (eq currentSign 'Козоріг')}}selected{{/if}}>Козоріг♑</option>
            <option value="Водолій" {{#if (eq currentSign 'Водолій')}}selected{{/if}}>Водолій</option>
            <option value="Риби" {{#if (eq currentSign 'Риби')}}selected{{/if}}>Риби♓</option>
            <option value="Овен" {{#if (eq currentSign 'Овен')}}selected{{/if}}>Овен♈</option>
            <option value="Телець" {{#if (eq currentSign 'Телець')}}selected{{/if}}>Телець♉</option>
            <option value="Близнюки" {{#if (eq currentSign 'Близнюки')}}selected{{/if}}>Близнюки♊</option>
            <option value="Рак" {{#if (eq currentSign 'Рак')}}selected{{/if}}>Рак♋</option>
            <option value="Лев" {{#if (eq currentSign 'Лев')}}selected{{/if}}>Лев♌</option>
            <option value="Діва" {{#if (eq currentSign 'Діва')}}selected{{/if}}>Діва♍</option>
            <option value="Терези" {{#if (eq currentSign 'Терези')}}selected{{/if}}>Терези♎</option>
            <option value="Скорпіон" {{#if (eq currentSign 'Скорпіон')}}selected{{/if}}>Скорпіон♏</option>
            <option value="Стрілець" {{#if (eq currentSign 'Стрілець')}}selected{{/if}}>Стрілець♐</option>
        </select>

        <select name="month" class="filter-select">
            <option value="">Всі місяці</option>
            <option value="Січень" {{#if (eq currentMonth 'Січень')}}selected{{/if}}>Січень🎄</option>
            <option value="Лютий" {{#if (eq currentMonth 'Лютий')}}selected{{/if}}>Лютий🏔️</option>
            <option value="Березень" {{#if (eq currentMonth 'Березень')}}selected{{/if}}>Березень🌱</option>
            <option value="Квітень" {{#if (eq currentMonth 'Квітень')}}selected{{/if}}>Квітень🌸</option>
            <option value="Травень" {{#if (eq currentMonth 'Травень')}}selected{{/if}}>Травень🌿</option>
            <option value="Червень" {{#if (eq currentMonth 'Червень')}}selected{{/if}}>Червень🌞</option>
            <option value="Липень" {{#if (eq currentMonth 'Липень')}}selected{{/if}}>Липень🌊</option>
            <option value="Серпень" {{#if (eq currentMonth 'Серпень')}}selected{{/if}}>Серпень🍉</option>
            <option value="Вересень" {{#if (eq currentMonth 'Вересень')}}selected{{/if}}>Вересень☁️</option>
            <option value="Жовтень" {{#if (eq currentMonth 'Жовтень')}}selected{{/if}}>Жовтень🎃</option>
            <option value="Листопад" {{#if (eq currentMonth 'Листопад')}}selected{{/if}}>Листопад🍂</option>
            <option value="Грудень" {{#if (eq currentMonth 'Грудень')}}selected{{/if}}>Грудень❄️</option>
        </select>

        <button type="submit" class="filter-btn">Фільтрувати</button>
        <a href="/db" class="filter-btn-reset">Скинути</a>
                </form>
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Знак</th>
                                <th scope="col">Місяць</th>
                                <th scope="col">Гороскоп</th>
                                <th scope="col">Реакції</th>
                            </tr>
                        </thead>
                            <tbody>
                                {{#each horoscope }}
                                    <tr>
                                        <td>{{this.sign}}</td>
                                        <td>{{this.month}}</td>
                                        <td>{{this.text}}</td>
                                        <td class="reaction-cell">
                                          <div class="reaction-group">
                                          <div class="reaction-item">
                                          <button class="btn-reaction {{#if (eq this.reaction 'bad')}}active{{/if}}"
                                                  onclick="setReaction({{this.id}}, 'bad', this)">🗑️</button>
                                            <span class="reaction-count"></span>
                                        </div>
                                            <div class="reaction-item">
                                        <button class="btn-reaction {{#if (eq this.reaction 'ok')}}active{{/if}}"
                                                onclick="setReaction({{this.id}}, 'ok', this)">😐</button>
                                            <span class="reaction-count"></span>
                                        </div>
                                            <div class="reaction-item">
                                        <button class="btn-reaction {{#if (eq this.reaction 'good')}}active{{/if}}"
                                                 onclick="setReaction({{this.id}}, 'good', this)">🔥</button>
                                            <span class="reaction-count"></span>
                                         </div>
                                            </div>
                                        </td>
                                {{/each}}
                            </tbody>
                        </table>
                    <script>
                     function setReaction(id, reaction, btn) {
                     fetch('/reaction', {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json' },
                     body: JSON.stringify({ id, reaction })
                      })
                    .then(res => res.json())
                    .then(data => {
                    if (!data.ok) return;
                    const group = btn.closest('.reaction-group');
                    group.querySelectorAll('.btn-reaction').forEach(b => {
                    b.classList.remove('active');
                    });
                    btn.classList.add('active');
                    })
                    .catch(err => console.error(err));
                    }
                    </script>
            </body>
        </style>
    </head>
